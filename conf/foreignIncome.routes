POST       /:taxYear/dividends/:countryCode/foreign-tax-deducted-from-dividend-income                           controllers.foreignincome.dividends.ForeignTaxDeductedFromDividendIncomeController.onSubmit(taxYear: Int, countryCode: String, mode: Mode = NormalMode)
GET        /:taxYear/dividends/:countryCode/change-foreign-tax-deducted-from-dividend-income                     controllers.foreignincome.dividends.ForeignTaxDeductedFromDividendIncomeController.onPageLoad(taxYear: Int, countryCode: String, mode: Mode = CheckMode)
POST       /:taxYear/dividends/:countryCode/change-foreign-tax-deducted-from-dividend-income                     controllers.foreignincome.dividends.ForeignTaxDeductedFromDividendIncomeController.onSubmit(taxYear: Int, countryCode: String, mode: Mode = CheckMode)
